          <p style={{ fontSize: "13px", lineHeight: "1.6" }}>{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
);

const TrainingCycle = () => {
  const [activeDay, setActiveDay] = useState(0);
  const day = TETRAD[activeDay];

  return (
    <div style={s.section}>
      <h2 style={{ color: C.marble }}>The Tetrad System</h2>
      <div style={{ display: "flex", gap: "10px", margin: "20px 0", flexWrap: "wrap" }}>
        {TETRAD.map((d, i) => (
          <button key={i} onClick={() => setActiveDay(i)} style={s.navBtn(activeDay === i)}>Day {d.day}</button>
        ))}
      </div>
      <div style={s.card(day.color)}>
        <h3 style={{ color: day.color }}>{day.gk} — {day.name}</h3>
        <p style={{ fontStyle: "italic", fontSize: "13px", color: C.marbleDim }}>{day.ancientPurpose}</p>
        {day.sessions.map((sess, si) => (
          <div key={si} style={{ marginTop: "20px" }}>
            <div style={{ fontSize: "11px", color: day.color, fontWeight: "bold" }}>{sess.phase} ({sess.duration})</div>
            <table style={s.table}>
              <thead>
                <tr>
                  <th style={s.th}>Movement</th>
                  <th style={s.th}>Ancient Context</th>
                </tr>
              </thead>
              <tbody>
                {sess.items.map((item, ii) => (
                  <tr key={ii}>
                    <td style={s.td}><strong>{item.act}</strong></td>
                    <td style={{ ...s.td, color: C.muted }}>{item.equiv}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}
      </div>
    </div>
  );
};

