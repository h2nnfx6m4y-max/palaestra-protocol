/* ── STYLES ── */
const s = {
  app: { background: C.bg, minHeight: "100vh", color: C.text, fontFamily: "serif", overflowX: "hidden" },
  hero: { background: `radial-gradient(ellipse at 50% 0%, #2a1e08 0%, ${C.bg} 70%)`, padding: "50px 20px", textAlign: "center", borderBottom: `1px solid ${C.goldDim}` },
