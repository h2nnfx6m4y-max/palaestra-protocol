/* ── COMPONENTS ── */
const Row = ({ children, color }) => (
  <div style={{ display: "flex", gap: "10px", padding: "5px 0", alignItems: "center" }}>
    <div style={{ width: "6px", height: "6px", borderRadius: "50%", background: color || C.gold }} />
    <div style={{ fontSize: "14px" }}>{children}</div>
  </div>
);

const Philosophy = () => (
  <div style={s.section}>
    <h2 style={{ color: C.marble }}>Greek Athletic Philosophy</h2>
